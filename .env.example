# Provider: openrouter (free models available, no credit card) — DEFAULT
OPENROUTER_API_KEY=sk-or-your-key-here

# Provider: groq (free, no credit card)
GROQ_API_KEY=gsk_your-key-here

# Provider: openai (paid)
OPENAI_API_KEY=sk-your-key-here

# Provider: gemini (requires billing since 2026)
GEMINI_API_KEY=your-key-here

# Set which provider to use in config/config.yaml → llm.provider
